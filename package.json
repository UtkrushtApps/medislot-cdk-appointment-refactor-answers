{
  "name": "medislot-cdk-appointment-refactor",
  "version": "1.0.0",
  "description": "MediSlot healthcare appointment scheduling infrastructure (AWS CDK)",
  "bin": {
    "medislot": "bin/app.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "synth": "cdk synth --all",
    "synth:dev": "cdk synth -c env=dev",
    "synth:staging": "cdk synth -c env=staging",
    "diff:dev": "cdk diff -c env=dev",
    "diff:staging": "cdk diff -c env=staging",
    "test": "jest"
  },
  "devDependencies": {
    "@types/jest": "29.5.12",
    "@types/node": "20.11.30",
    "aws-cdk": "2.130.0",
    "jest": "29.7.0",
    "ts-jest": "29.1.2",
    "ts-node": "10.9.2",
    "typescript": "5.4.3"
  },
  "dependencies": {
    "aws-cdk-lib": "2.130.0",
    "constructs": "10.3.0",
    "source-map-support": "0.5.21"
  }
}
